---
layout: layout.vto
title: Home
---

<section class="pages">
	{{ for p of collections.pages |> sortPages }}
		<a href="{{ p.url }}">{{ p.data.title }}</a>
	{{ /for }}
</section>

<div class="grid">
	{{ for p of collections.posts |> sortPosts }}
		<span class="date">{{ p.data.date |> formatDate }}</span>
		<span><a href="{{ p.url }}">{{ p.data.title }}</a></span>
	{{ /for }}
</div>

<p><a href="/The-Iron-Ragdoll">The Iron Ragdoll</a>, my paracosm!</p>
